#!/usr/bin/env python3
import os
import sys
from pathlib import Path

os.environ.setdefault("WEBKIT_DISABLE_COMPOSITING_MODE", "1")
os.environ.setdefault("WEBKIT_DISABLE_DMABUF_RENDERER", "1")

if not os.environ.get("DISPLAY"):
    for candidate in (":1", ":0", ":2"):
        if Path(f"/tmp/.X11-unix/X{candidate.lstrip(':')}").exists():
            os.environ["DISPLAY"] = candidate
            break
    else:
        os.environ.setdefault("DISPLAY", ":0")

SCRIPT = Path(__file__).resolve()
SCRIPT_DIR = SCRIPT.parent

UI_CANDIDATES = (
    SCRIPT_DIR.parent / "shared" / "ui",
    Path("/usr/share/nova-browser/ui"),
)
for ui_path in UI_CANDIDATES:
    if (ui_path / "index.html").is_file():
        os.environ.setdefault("NOVA_BROWSER_UI", str(ui_path))
        break

PACKAGE_ROOTS = (
    SCRIPT_DIR,
    Path("/usr/lib/nova-browser"),
)

for root in PACKAGE_ROOTS:
    if (root / "nova_browser").is_dir():
        sys.path.insert(0, str(root))
        break
else:
    installed = Path("/usr/lib/nova-browser")
    if (installed / "app.py").is_file():
        raise SystemExit(
            "Nova Browser installation is outdated.\n"
            "Reinstall: sudo dpkg -i dist/nova-browser_1.0.0_all.deb"
        )
    raise SystemExit(
        "Nova Browser not found.\n"
        'Run: "/home/isaiah/Projects/Nova Browser/Nova-Browser"'
    )

from nova_browser.app import main

if __name__ == "__main__":
    raise SystemExit(main())
